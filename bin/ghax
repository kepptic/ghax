#!/usr/bin/env bash
# ghax CLI shim — selects the binary to exec, in this order:
#
#   1. $GHAX_BIN            — explicit override (CI, multi-agent isolation, testing)
#   2. target/release/ghax  — in-repo Rust build
#   3. exit 10              — nothing usable found; print build hint
#
# For installed users (via `bun run install-link` or a release archive) the
# binary is on PATH and this shim is never invoked. The precedence only
# matters for in-repo use during development.

set -e

DIR="$(cd "$(dirname "$0")/.." && pwd)"

# 1. Explicit override.
if [ -n "${GHAX_BIN:-}" ] && [ -x "$GHAX_BIN" ]; then
  exec "$GHAX_BIN" "$@"
fi

# 2. Rust binary.
if [ -x "$DIR/target/release/ghax" ]; then
  exec "$DIR/target/release/ghax" "$@"
fi

# 3. Nothing found.
echo "ghax: no Rust binary at $DIR/target/release/ghax." >&2
echo "" >&2
echo "  Build it:  cd $DIR && bun run build:rust" >&2
echo "  Or set GHAX_BIN to point at a pre-built ghax binary." >&2
exit 10
